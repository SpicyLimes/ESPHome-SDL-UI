#!/bin/bash
#
# ESPHome SDL UI - Main Launcher
# A web-based tool for testing ESPHome configurations on SDL2 platform
#

set -e

# ============================================================================
# Configuration
# ============================================================================
APP_NAME="ESPHome SDL UI"
APP_VERSION="2.0.0"
APP_PORT=6062
APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INTERNAL_DIR="$APP_DIR/.esphome-sdl-ui"
VENV_DIR="$INTERNAL_DIR/venv"
PID_FILE="$INTERNAL_DIR/pid"
LOG_FILE="$APP_DIR/logs/app.log"
CONFIG_FILE="$INTERNAL_DIR/config"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

# ============================================================================
# Helper Functions
# ============================================================================
print_header() {
    clear
    echo ""
    echo -e "${CYAN}    ███████${BLUE}╗${CYAN}███████${BLUE}╗${CYAN}██████${BLUE}╗ ${NC}"
    echo -e "${CYAN}    ██${BLUE}╔════╝${CYAN}██${BLUE}╔════╝${CYAN}██${BLUE}╔══${CYAN}██${BLUE}╗${NC}    ${WHITE}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${NC}"
    echo -e "${CYAN}    █████${BLUE}╗  ${CYAN}███████${BLUE}╗${CYAN}██████${BLUE}╔╝${NC}    ${WHITE}┃${NC}   ${BOLD}${MAGENTA}S${CYAN}D${BLUE}L${NC}${BOLD}  ${WHITE}U${NC}${BOLD}ser ${WHITE}I${NC}${BOLD}nterface${NC}      ${WHITE}┃${NC}"
    echo -e "${CYAN}    ██${BLUE}╔══╝  ╚════${CYAN}██${BLUE}║${CYAN}██${BLUE}╔═══╝ ${NC}    ${WHITE}┃${NC}   ${DIM}ESPHome Display Tester${NC}   ${WHITE}┃${NC}"
    echo -e "${CYAN}    ███████${BLUE}╗${CYAN}███████${BLUE}║${CYAN}██${BLUE}║     ${NC}    ${WHITE}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${NC}"
    echo -e "${BLUE}    ╚══════╝╚══════╝╚═╝     ${NC}    ${DIM}Version ${APP_VERSION}${NC}"
    echo ""
    echo -e "    ${DIM}────────────────────────────────────────────────────────────${NC}"
    echo ""
}

print_status() {
    if is_running; then
        echo -e "  Status: ${GREEN}● Running${NC} on ${BOLD}http://localhost:$APP_PORT${NC}"
    else
        echo -e "  Status: ${RED}○ Stopped${NC}"
    fi
    echo ""
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}!${NC} $1"
}

print_info() {
    echo -e "${BLUE}→${NC} $1"
}

is_running() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            return 0
        fi
    fi
    return 1
}

get_pid() {
    if [ -f "$PID_FILE" ]; then
        cat "$PID_FILE"
    fi
}

check_port_available() {
    if command -v ss &> /dev/null; then
        ! ss -tuln | grep -q ":$APP_PORT "
    elif command -v netstat &> /dev/null; then
        ! netstat -tuln | grep -q ":$APP_PORT "
    else
        # Assume available if we can't check
        return 0
    fi
}

load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
}

save_config() {
    echo "ESPHOME_PATH=\"$ESPHOME_PATH\"" > "$CONFIG_FILE"
    echo "SDL2_INSTALLED=\"$SDL2_INSTALLED\"" >> "$CONFIG_FILE"
    echo "SETUP_COMPLETE=\"true\"" >> "$CONFIG_FILE"
}

# ============================================================================
# Setup Functions
# ============================================================================
check_python() {
    if command -v python3 &> /dev/null; then
        local version=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
        local major=$(echo $version | cut -d. -f1)
        local minor=$(echo $version | cut -d. -f2)
        if [ "$major" -ge 3 ] && [ "$minor" -ge 10 ]; then
            print_success "Python $version"
            return 0
        else
            print_error "Python $version (requires 3.10+)"
            return 1
        fi
    else
        print_error "Python 3 not found"
        return 1
    fi
}

check_permissions() {
    if [ -w "$APP_DIR" ]; then
        print_success "Write permissions"
        return 0
    else
        print_error "No write permission in $APP_DIR"
        return 1
    fi
}

detect_esphome() {
    # Check common locations for ESPHome
    local locations=(
        "$(which esphome 2>/dev/null)"
        "$HOME/.local/bin/esphome"
        "$HOME/esphome/venv/bin/esphome"
        "$HOME/esphome-venv/bin/esphome"
    )

    # Also search in common venv directories
    while IFS= read -r -d '' venv; do
        if [ -f "$venv/bin/esphome" ]; then
            locations+=("$venv/bin/esphome")
        fi
    done < <(find "$HOME" -maxdepth 4 -type d -name "venv" -print0 2>/dev/null)

    for loc in "${locations[@]}"; do
        if [ -n "$loc" ] && [ -x "$loc" ]; then
            # Verify it's actually ESPHome
            if "$loc" version &> /dev/null; then
                echo "$loc"
                return 0
            fi
        fi
    done

    return 1
}

detect_sdl2() {
    # Check if SDL2 is installed via package manager
    if dpkg -l 2>/dev/null | grep -q "libsdl2-2.0-0"; then
        return 0
    fi

    # Check via ldconfig
    if ldconfig -p 2>/dev/null | grep -q "libSDL2"; then
        return 0
    fi

    return 1
}

get_esphome_version() {
    local esphome_path="$1"
    if [ -n "$esphome_path" ] && [ -x "$esphome_path" ]; then
        "$esphome_path" version 2>/dev/null | head -1
    fi
}

install_sdl2() {
    print_info "Installing SDL2 libraries..."
    if command -v apt-get &> /dev/null; then
        sudo apt-get update -qq
        sudo apt-get install -y -qq libsdl2-2.0-0 libsdl2-dev > /dev/null 2>&1
        if [ $? -eq 0 ]; then
            print_success "SDL2 installed successfully"
            return 0
        fi
    fi
    print_error "Failed to install SDL2"
    return 1
}

install_esphome() {
    print_info "Installing ESPHome in app virtual environment..."

    # Ensure venv exists
    if [ ! -d "$VENV_DIR" ]; then
        python3 -m venv "$VENV_DIR"
    fi

    source "$VENV_DIR/bin/activate"
    pip install --quiet --upgrade pip
    pip install --quiet esphome
    deactivate

    if [ -x "$VENV_DIR/bin/esphome" ]; then
        print_success "ESPHome installed successfully"
        echo "$VENV_DIR/bin/esphome"
        return 0
    fi

    print_error "Failed to install ESPHome"
    return 1
}

create_venv() {
    print_info "Creating virtual environment..."

    if [ ! -d "$VENV_DIR" ]; then
        python3 -m venv "$VENV_DIR"
    fi

    source "$VENV_DIR/bin/activate"
    pip install --quiet --upgrade pip
    pip install --quiet -r "$APP_DIR/requirements.txt"
    deactivate

    print_success "Virtual environment ready"
}

run_setup() {
    print_header
    echo -e "${BOLD}  First Time Setup${NC}"
    echo ""
    echo "  Checking system requirements..."
    echo ""

    local setup_ok=true

    # Check Python
    echo -n "  "
    if ! check_python; then
        setup_ok=false
    fi

    # Check permissions
    echo -n "  "
    if ! check_permissions; then
        setup_ok=false
    fi

    if [ "$setup_ok" = false ]; then
        echo ""
        print_error "Setup cannot continue. Please fix the issues above."
        exit 1
    fi

    echo ""
    echo "  Scanning for existing installations..."
    echo ""

    # Detect ESPHome
    local detected_esphome=""
    local esphome_version=""
    if detected_esphome=$(detect_esphome); then
        esphome_version=$(get_esphome_version "$detected_esphome")
        print_success "ESPHome found: $detected_esphome"
        echo -e "           Version: ${CYAN}$esphome_version${NC}"
    else
        print_warning "ESPHome not found in common locations"
    fi

    # Detect SDL2
    echo -n "  "
    local sdl2_found=false
    if detect_sdl2; then
        print_success "SDL2 libraries installed"
        sdl2_found=true
    else
        print_warning "SDL2 libraries not found"
    fi

    echo ""

    # Handle ESPHome
    if [ -n "$detected_esphome" ]; then
        echo -e "  ${BOLD}Use detected ESPHome?${NC}"
        echo ""
        echo "  1) Yes, use $detected_esphome"
        echo "  2) No, enter a different path"
        echo "  3) No, install a fresh copy"
        echo ""
        read -p "  Select [1-3]: " esphome_choice

        case $esphome_choice in
            1)
                ESPHOME_PATH="$detected_esphome"
                ;;
            2)
                echo ""
                read -p "  Enter path to ESPHome executable: " custom_path
                if [ -x "$custom_path" ] && "$custom_path" version &> /dev/null; then
                    ESPHOME_PATH="$custom_path"
                    print_success "ESPHome verified at $custom_path"
                else
                    print_error "Invalid ESPHome path"
                    exit 1
                fi
                ;;
            3)
                ESPHOME_PATH=$(install_esphome)
                ;;
            *)
                ESPHOME_PATH="$detected_esphome"
                ;;
        esac
    else
        echo -e "  ${BOLD}ESPHome is required. Options:${NC}"
        echo ""
        echo "  1) Install ESPHome automatically"
        echo "  2) Enter path to existing ESPHome"
        echo "  3) Exit and install manually"
        echo ""
        read -p "  Select [1-3]: " esphome_choice

        case $esphome_choice in
            1)
                ESPHOME_PATH=$(install_esphome)
                if [ -z "$ESPHOME_PATH" ]; then
                    exit 1
                fi
                ;;
            2)
                read -p "  Enter path to ESPHome executable: " custom_path
                if [ -x "$custom_path" ] && "$custom_path" version &> /dev/null; then
                    ESPHOME_PATH="$custom_path"
                    print_success "ESPHome verified"
                else
                    print_error "Invalid ESPHome path"
                    exit 1
                fi
                ;;
            3)
                echo ""
                echo "  Install ESPHome with: pip install esphome"
                echo "  Then run this setup again."
                exit 0
                ;;
            *)
                exit 1
                ;;
        esac
    fi

    echo ""

    # Handle SDL2
    if [ "$sdl2_found" = false ]; then
        echo -e "  ${BOLD}SDL2 is required for display preview. Options:${NC}"
        echo ""
        echo "  1) Install SDL2 automatically (requires sudo)"
        echo "  2) Skip (app will work but SDL2 preview won't)"
        echo "  3) Exit and install manually"
        echo ""
        read -p "  Select [1-3]: " sdl2_choice

        case $sdl2_choice in
            1)
                echo ""
                if install_sdl2; then
                    SDL2_INSTALLED="true"
                else
                    SDL2_INSTALLED="false"
                fi
                ;;
            2)
                print_warning "Skipping SDL2 - preview will not work"
                SDL2_INSTALLED="false"
                ;;
            3)
                echo ""
                echo "  Install SDL2 with: sudo apt install libsdl2-2.0-0 libsdl2-dev"
                echo "  Then run this setup again."
                exit 0
                ;;
            *)
                SDL2_INSTALLED="false"
                ;;
        esac
    else
        SDL2_INSTALLED="true"
    fi

    echo ""

    # Create virtual environment for app
    create_venv

    # Save configuration
    save_config

    echo ""
    print_success "Setup complete!"
    echo ""
    read -p "  Press Enter to continue to the main menu..."
}

# ============================================================================
# App Control Functions
# ============================================================================
start_app() {
    if is_running; then
        print_warning "App is already running (PID: $(get_pid))"
        return 1
    fi

    if ! check_port_available; then
        print_error "Port $APP_PORT is already in use"
        return 1
    fi

    print_info "Starting $APP_NAME..."

    # Ensure log directory exists
    mkdir -p "$APP_DIR/logs"

    # Start the app
    source "$VENV_DIR/bin/activate"
    cd "$APP_DIR/app"

    # Export ESPHome path for the app to use
    export ESPHOME_PATH="$ESPHOME_PATH"
    export APP_PORT="$APP_PORT"

    nohup python -m uvicorn main:app --host 127.0.0.1 --port $APP_PORT > "$LOG_FILE" 2>&1 &
    local pid=$!
    echo $pid > "$PID_FILE"

    deactivate
    cd "$APP_DIR"

    # Wait a moment and verify it started
    sleep 2

    if is_running; then
        print_success "App started successfully (PID: $pid)"

        # Open browser
        if command -v xdg-open &> /dev/null; then
            xdg-open "http://localhost:$APP_PORT" &> /dev/null &
        elif command -v open &> /dev/null; then
            open "http://localhost:$APP_PORT" &> /dev/null &
        fi

        echo ""
        echo -e "  ${BOLD}Access the UI at:${NC} ${CYAN}http://localhost:$APP_PORT${NC}"
    else
        print_error "App failed to start. Check logs with option 4."
        rm -f "$PID_FILE"
        return 1
    fi
}

stop_app() {
    if ! is_running; then
        print_warning "App is not running"
        return 1
    fi

    local pid=$(get_pid)
    print_info "Stopping $APP_NAME (PID: $pid)..."

    # Graceful shutdown
    kill -TERM "$pid" 2>/dev/null

    # Wait up to 5 seconds
    local count=0
    while [ $count -lt 5 ] && ps -p "$pid" > /dev/null 2>&1; do
        sleep 1
        ((count++))
    done

    # Force kill if still running
    if ps -p "$pid" > /dev/null 2>&1; then
        print_warning "Graceful shutdown failed, forcing..."
        kill -KILL "$pid" 2>/dev/null
        sleep 1
    fi

    rm -f "$PID_FILE"

    if ! ps -p "$pid" > /dev/null 2>&1; then
        print_success "App stopped"
    else
        print_error "Failed to stop app"
        return 1
    fi
}

show_status() {
    echo ""
    if is_running; then
        local pid=$(get_pid)
        echo -e "  ${GREEN}● App is running${NC}"
        echo ""
        echo "    PID:  $pid"
        echo "    Port: $APP_PORT"
        echo "    URL:  http://localhost:$APP_PORT"
        echo ""

        # Show resource usage
        if command -v ps &> /dev/null; then
            local mem=$(ps -p $pid -o rss= 2>/dev/null | awk '{print int($1/1024)"MB"}')
            local cpu=$(ps -p $pid -o %cpu= 2>/dev/null)
            echo "    Memory: $mem"
            echo "    CPU:    $cpu%"
        fi
    else
        echo -e "  ${RED}○ App is not running${NC}"
    fi
    echo ""
}

show_logs() {
    if [ -f "$LOG_FILE" ]; then
        echo ""
        echo -e "  ${BOLD}Recent logs:${NC} (Press Ctrl+C to exit)"
        echo ""
        tail -50 "$LOG_FILE"
        echo ""
        echo -e "  ${CYAN}Following new log entries...${NC}"
        tail -f "$LOG_FILE"
    else
        print_warning "No log file found"
    fi
}

update_app() {
    echo ""
    print_info "Checking for updates..."

    if [ -d "$APP_DIR/.git" ]; then
        cd "$APP_DIR"

        # Fetch updates
        git fetch origin 2>/dev/null

        local local_hash=$(git rev-parse HEAD)
        local remote_hash=$(git rev-parse origin/main 2>/dev/null || git rev-parse origin/master 2>/dev/null)

        if [ "$local_hash" = "$remote_hash" ]; then
            print_success "Already up to date"
        else
            print_info "Updates available. Downloading..."

            # Stop app if running
            if is_running; then
                stop_app
            fi

            # Pull updates
            git pull origin main 2>/dev/null || git pull origin master 2>/dev/null

            # Reinstall dependencies
            source "$VENV_DIR/bin/activate"
            pip install --quiet -r "$APP_DIR/requirements.txt"
            deactivate

            print_success "Update complete"
        fi
    else
        print_warning "Not a git repository - cannot auto-update"
        echo "  Download manually from GitHub"
    fi
    echo ""
}

uninstall_app() {
    echo ""
    echo -e "  ${BOLD}${RED}Uninstall $APP_NAME${NC}"
    echo ""
    echo "  This will remove:"
    echo "    - Virtual environment (~50MB)"
    echo "    - Configuration files"
    echo ""
    echo "  Your configs and backups will be kept unless you choose to remove them."
    echo ""
    read -p "  Are you sure? [y/N]: " confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Stop if running
        if is_running; then
            stop_app
        fi

        # Remove venv and internal files
        rm -rf "$INTERNAL_DIR"
        print_success "Removed virtual environment and config"

        read -p "  Also remove configs and backups? [y/N]: " remove_data
        if [[ "$remove_data" =~ ^[Yy]$ ]]; then
            rm -rf "$APP_DIR/configs"/* "$APP_DIR/backups"/* "$APP_DIR/logs"/*
            print_success "Removed user data"
        fi

        echo ""
        print_success "Uninstall complete"
        echo "  You can delete the $APP_DIR folder to fully remove the app."
        echo ""
        exit 0
    else
        print_info "Uninstall cancelled"
    fi
    echo ""
}

# ============================================================================
# Main Menu
# ============================================================================
show_menu() {
    while true; do
        print_header
        print_status

        echo -e "  ${BOLD}Options:${NC}"
        echo ""
        echo "    1) Start App"
        echo "    2) Stop App"
        echo "    3) App Status"
        echo "    4) View Logs"
        echo "    5) Update App"
        echo "    6) Uninstall"
        echo ""
        echo "    q) Quit"
        echo ""

        read -p "  Select option: " choice

        case $choice in
            1)
                echo ""
                start_app
                echo ""
                read -p "  Press Enter to continue..."
                ;;
            2)
                echo ""
                stop_app
                echo ""
                read -p "  Press Enter to continue..."
                ;;
            3)
                show_status
                read -p "  Press Enter to continue..."
                ;;
            4)
                show_logs
                ;;
            5)
                update_app
                read -p "  Press Enter to continue..."
                ;;
            6)
                uninstall_app
                read -p "  Press Enter to continue..."
                ;;
            q|Q)
                echo ""
                if is_running; then
                    echo -e "  ${YELLOW}The app is still running.${NC}"
                    echo ""
                    echo "  1) Stop app and quit"
                    echo "  2) Keep app running in background and quit"
                    echo "  3) Cancel - return to menu"
                    echo ""
                    read -p "  Select [1-3]: " quit_choice
                    case $quit_choice in
                        1)
                            stop_app
                            echo ""
                            echo -e "  ${GREEN}Goodbye!${NC}"
                            echo ""
                            exit 0
                            ;;
                        2)
                            echo ""
                            echo -e "  ${CYAN}App will continue running at http://localhost:$APP_PORT${NC}"
                            echo -e "  ${DIM}Run ./esphome-sdl-ui again to manage it.${NC}"
                            echo ""
                            echo -e "  ${GREEN}Goodbye!${NC}"
                            echo ""
                            exit 0
                            ;;
                        3|*)
                            # Return to menu
                            ;;
                    esac
                else
                    echo -e "  ${GREEN}Goodbye!${NC}"
                    echo ""
                    exit 0
                fi
                ;;
            *)
                print_warning "Invalid option"
                sleep 1
                ;;
        esac
    done
}

# ============================================================================
# Main Entry Point
# ============================================================================
main() {
    # Create internal directory if needed
    mkdir -p "$INTERNAL_DIR"
    mkdir -p "$APP_DIR/logs"

    # Load existing config
    load_config

    # Check if setup is complete
    if [ "$SETUP_COMPLETE" != "true" ] || [ ! -d "$VENV_DIR" ]; then
        run_setup
    fi

    # Verify ESPHome path still valid
    if [ -n "$ESPHOME_PATH" ] && [ ! -x "$ESPHOME_PATH" ]; then
        print_warning "Configured ESPHome path no longer valid"
        SETUP_COMPLETE="false"
        run_setup
    fi

    # Show main menu
    show_menu
}

# Run main function
main "$@"
